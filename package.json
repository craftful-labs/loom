{
  "name": "loom",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "description": "A simple example library built by tsdown",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "rehype-stringify": "^10.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "prettier": "^3.8.3",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2"
  }
}
