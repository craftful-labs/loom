{
  "name": "@craftful/loom",
  "type": "module",
  "version": "0.1.0",
  "packageManager": "pnpm@10.27.0",
  "description": "Opinionated markdown-to-HTML preprocessor for Svelte and plain HTML.",
  "license": "MIT",
  "homepage": "https://github.com/craftful-labs/loom#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/craftful-labs/loom.git"
  },
  "bugs": {
    "url": "https://github.com/craftful-labs/loom/issues"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "loom",
    "markdown",
    "svelte"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
  },
  "peerDependencies": {
    "prettier": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "prettier": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "@types/node": "^25.6.0",
    "prettier": "^3.8.3",
    "publint": "^0.3.18",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./prettier": "./dist/prettier.mjs",
    "./svelte": "./dist/svelte.mjs",
    "./package.json": "./package.json"
  }
}
